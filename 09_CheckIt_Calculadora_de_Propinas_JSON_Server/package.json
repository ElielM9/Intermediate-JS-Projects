{
  "name": "09_calculadora_de_propinas_json_server",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "htmlmin": "html-minifier --input-dir src/views --output-dir public --collapse-whitespace --remove-comments --file-ext html",
    "build:styles": "postcss src/styles/styles.css -o public/styles/styles.css",
    "copy:bootstrap": "cp node_modules/bootstrap/dist/js/bootstrap.bundle.min.js public/js/vendors/",
    "minify:js": "node minify.js",
    "build": "npm run htmlmin && npm run build:styles && npm run copy:bootstrap && npm run minify:js",
    "dev": "npm run build",
    "dev:watch": "nodemon -w src/ -e js,css,html --exec \"npm run dev\""
  },
  "author": "ElielM9",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^8.0.0",
    "autoprefixer": "^10.4.27",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "cssnano": "^7.1.3",
    "glob": "^13.0.6",
    "html-minifier": "^4.0.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "terser": "^5.46.1"
  }
}
